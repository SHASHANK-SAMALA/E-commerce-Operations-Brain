# ── Azure OpenAI (same endpoint pattern as Langraph_MCP) ─────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL=gpt-oss-120b
# Set to your mini deployment name if you have one, otherwise leave blank to reuse AZURE_OPENAI_MODEL
AZURE_OPENAI_MODEL_MINI=gpt-4o-mini-2024-07-18
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small-1
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce_brain

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Security ──────────────────────────────────────────────────────────────
# Single API key — never commit a real value to git
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ecommerce-brain

# ── Mem0 (optional — semantic memory layer) ──────────────────────────────────
# mem0ai uses the same pgvector + Azure OpenAI config above; no extra keys needed.

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ecommerce-brain
PROMETHEUS_PORT=8001

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── LLM Cost Control ──────────────────────────────────────────────────────────
LLM_REQUEST_TIMEOUT=30
MAX_TOKENS_PER_INVESTIGATION=12000

# ── Routing fallback (optional — Mistral-7B via Ollama) ───────────────────────
# Set to true only if Ollama is running locally with `ollama pull mistral`
USE_LOCAL_ROUTING_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
